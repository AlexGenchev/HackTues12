# Smart Box — Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Backend URL (used by Raspberry Pi scripts)
BACKEND_URL=http://<YOUR_BACKEND_IP>:8000/complaints/upload

# Groq API key (used by backend AI services)
GROQ_API_KEY=your_groq_key_here

# Email credentials (used by backend email service)
EMAIL_SENDER=your_email@example.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
